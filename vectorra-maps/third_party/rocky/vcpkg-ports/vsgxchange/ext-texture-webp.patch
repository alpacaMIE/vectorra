         samplerImage.sampler = vsg_samplers[gltf_texture->sampler.value];
     }
 
-    if (gltf_texture->source)
+    auto source = gltf_texture->source;
+
+    // EXT_texture_webp stores the image index in the extension instead of texture.source
+    if (!source)
+    {
+        if (auto texture_webp = gltf_texture->extension<EXT_texture_webp>("EXT_texture_webp"))
+        {
+            source = texture_webp->source;
+        }
+    }
+
+    if (source)
     {
-        samplerImage.image = vsg_images[gltf_texture->source.value];
+        samplerImage.image = vsg_images[source.value];
     }
 
     return samplerImage;
